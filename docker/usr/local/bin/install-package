#!/bin/sh
set -e

# If we are not root, rerun using sudo
if ! [ $(id -u) = 0 ]; then
    sudo "$0" "$@"
else
    # Update apt, install the packages and cleanup the cache to make the layer smaller
    apt-get update
    apt-get install -y --no-install-recommends "$@"
    rm -rf /var/cache/apt /var/lib/apt/lists/*
fi
