{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "target": "ESNext",
    "useDefineForClassFields": false,
    "jsx": "react",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "declaration": false,
    "removeComments": true,
    "strict": true,
    "outDir": "dist",
    "lib": ["ESNext", "dom", "webworker"],
    "typeRoots": ["./node_modules/@types", "./typings"],
    "paths": {
      "@components/*": ["./src/client/components/*"],
      "@hooks/*": ["./src/client/hooks/*"],
      "@client/*": ["./src/client/*"],
      "@server/*": ["./src/server/*"],
      "@proto/*": ["./src/shared/proto/*"],
      "@shared/*": ["./src/shared/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src/**/*"],
  "exclude": ["**/tests/**/*", "**/_del/**/*"]
}
